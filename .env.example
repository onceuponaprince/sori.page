# sori.page environment variables

# Required — Anthropic API for LLM generation
ANTHROPIC_API_KEY="your_anthropic_api_key"

# Supabase — waitlist, auth, user data
SUPABASE_URL="your_supabase_url"
SUPABASE_SERVICE_KEY="your_supabase_service_role_key"
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Neo4j — knowledge graph (set by docker-compose for backend, needed for local dev)
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="soripage_dev_2024"

# Weaviate — vector store for RAG fallback
WEAVIATE_URL="http://localhost:8080"

# Context engine URL (for Next.js API proxy)
# Local Docker setup exposes context-engine on port 8001.
NEXT_PUBLIC_API_URL="http://localhost:8001"

# Optional browser-safe API key for white-label engine access.
# Only used if engine is configured to require API keys.
NEXT_PUBLIC_CONTEXT_ENGINE_API_KEY=""
NEXT_PUBLIC_CONTEXT_ENGINE_TENANT_ID=""

# Stripe billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""

# Postgres (Supabase)
# For Docker/Linux dev, prefer the Supabase pooler URL (IPv4-friendly):
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# If POSTGRES_POOLER_URL is set, backend uses it first.
POSTGRES_POOLER_URL=""
POSTGRES_URL=""
POSTGRES_DB="postgres"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=""
POSTGRES_HOST=""
POSTGRES_PORT="5432"
POSTGRES_SSLMODE="require"

# Optional — Reddit API for ingestion pipeline
# REDDIT_CLIENT_ID=""
# REDDIT_CLIENT_SECRET=""
# REDDIT_USER_AGENT="sori.page/0.1"

# Optional — IMDB fallback ingestion
# OMDb key used with: python manage.py ingest_imdb --source omdb --imdb-ids ...
OMDB_API_KEY=""
# Directory containing title.basics.tsv(.gz) and title.ratings.tsv(.gz)
IMDB_DATASETS_DIR="./data/imdb"

# Engine-only service configuration (used by backend/manage_engine.py)
# ENGINE_API_KEYS format:
#   tenantA:keyA,tenantB:keyB
# or for single-tenant installs:
#   keyOnly
ENGINE_REQUIRE_API_KEY="true"
ENGINE_API_KEYS=""
ENGINE_ALLOWED_ORIGINS="http://localhost:3000"
ENGINE_INCLUDE_INGESTION="false"
