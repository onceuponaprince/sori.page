# Context engine service (white-label) environment

DJANGO_SECRET_KEY="change-me"
DJANGO_DEBUG="false"

NEO4J_URI="bolt://neo4j:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="change-me"

WEAVIATE_URL="http://weaviate:8080"
ANTHROPIC_API_KEY=""

# Optional operator surface
ENGINE_INCLUDE_INGESTION="false"

# API key auth for white-label deployments
ENGINE_REQUIRE_API_KEY="true"
# Format: tenantA:keyA,tenantB:keyB
ENGINE_API_KEYS="demo-tenant:replace-me"
ENGINE_ALLOWED_ORIGINS="https://your-app.example.com"
